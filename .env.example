# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Groq API key — powers the live LLM extraction (free tier at https://console.groq.com).
# Without it, the app runs in replay mode using the cached sample extraction.
GROQ_API_KEY=your_groq_api_key_here

# Optional: force replay mode even when a key is set (reuses samples/extracted_live.json,
# never calls the API). Leave unset for normal live extraction.
# BL_RECONCILER_REPLAY=1
